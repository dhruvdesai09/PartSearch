### Database (Supabase Postgres)
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME

### CORS: comma-separated frontend origins, or * for any origin (credentials disabled — required for browsers).
### Example production: https://my-app.vercel.app
# CORS_ORIGINS=*

### Render / some hosts: Supabase may resolve to IPv6 first; those networks often need IPv4.
### Default when RENDER=true: force IPv4 (see main.py). Set to false only if you must.
# DB_FORCE_IPV4=true

### Optional tuning
OCR_ENABLED=true
OCR_RESOLUTION=300
LOG_LEVEL=INFO

# Parsing guardrails
# Minimum price for Format 1/2 rows to be considered valid (helps avoid OCR false positives).
PRICE_MIN=100
FORMAT2_PRICE_MIN=100
PRICE_MAX=100000
FORMAT2_PRICE_MAX=100000

# If true, /upload returns a `sample` of parsed rows (designation/price/pack/case)
# to help debug parsing issues. Do not leave enabled permanently in production.
UPLOAD_DEBUG=false

